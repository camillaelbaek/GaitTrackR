message: "If you use GaitTrackR in your research, please cite it as below."
title: "GaitTrackR: An interactive Shiny app for mouse gait analysis from paw-print coordinate data"
version: 1.0.0
date-released: 2025-01-01
license: MIT
url: "https://github.com/camillaelbaek/GaitTrackR"
repository-code: "https://github.com/camillaelbaek/GaitTrackR"
authors:
  - given-names: "Camilla"       # fill in your full name
    family-names: "Reiter Elbæk"             # fill in your family name
    alias: celbaek
    orcid: "https://orcid.org/0000-0002-6326-6047"   # replace with your ORCID
